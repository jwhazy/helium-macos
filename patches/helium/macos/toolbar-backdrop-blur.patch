+void BrowserFrameViewMac::UpdateToolbarBackdrop() {
+  NSWindow* window = GetWidget()->GetNativeWindow().GetNativeNSWindow();
+  if (!window) {
+    return;
+  }
+
+  NSView* host_view = GetWidget()->GetNativeView().GetNativeNSView();
+  NSView* superview = [host_view superview];
+  if (!superview) {
+    return;
+  }
+
+  const bool should_show = CanShowToolbarBackdrop(GetBrowserView()) &&
+                           GetBrowserView()->top_container()->height() > 0;
+  if (!should_show) {
+    [toolbar_backdrop_view_ setHidden:YES];
+    return;
+  }
+
+  if (!toolbar_backdrop_view_) {
+    toolbar_backdrop_view_ =
+        [[NSVisualEffectView alloc] initWithFrame:NSZeroRect];
+    [toolbar_backdrop_view_ setAutoresizingMask:NSViewWidthSizable |
+                                                NSViewMinYMargin];
+    [toolbar_backdrop_view_
+        setMaterial:NSVisualEffectMaterialUnderWindowBackground];
+    [toolbar_backdrop_view_
+        setBlendingMode:NSVisualEffectBlendingModeBehindWindow];
+    [toolbar_backdrop_view_
+        setState:NSVisualEffectStateFollowsWindowActiveState];
+  }
+
+  if ([toolbar_backdrop_view_ superview] != superview) {
+    [toolbar_backdrop_view_ removeFromSuperview];
+    [superview addSubview:toolbar_backdrop_view_
+               positioned:NSWindowBelow
+               relativeTo:host_view];
+  }
+
+  NSRect backdrop_frame = [superview bounds];
+  [toolbar_backdrop_view_ setFrame:backdrop_frame];
+  [toolbar_backdrop_view_ setHidden:NO];
+}
